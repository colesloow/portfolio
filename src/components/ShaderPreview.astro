---
// Renders a GLSL fragment shader on a full-screen WebGL canvas.
// Accepts the shader source as a raw string via the `code` prop.
// Uniforms available to the shader: u_resolution (vec2), u_time (float).
// The canvas background is transparent so the page background shows through.
const { code } = Astro.props;
const canvasId = `shader-${Math.random().toString(36).slice(2)}`;
---

<div class="shader-preview">
    <canvas id={canvasId} role="img" aria-label="Live shader animation"></canvas>
</div>

<style>
    .shader-preview {
        margin: 40px 0;
    }

    canvas {
        width: 100%;
        height: 400px;
        border-radius: 10px;
        background: transparent;
    }

    :global(.shader-error) {
        color: var(--text-muted);
        font-style: italic;
    }
</style>

<script is:inline define:vars={{ canvasId, code }}>
    window.addEventListener("DOMContentLoaded", () => {
        const canvas = document.getElementById(canvasId);

        if (!(canvas instanceof HTMLCanvasElement)) {
            console.error("ShaderPreview: canvas not found");
            return;
        }

        // Try standard webgl, fall back to experimental-webgl for older mobile browsers.
        const ctxOptions = { antialias: false, alpha: true };
        const gl = (
            canvas.getContext("webgl", ctxOptions) ||
            canvas.getContext("experimental-webgl", ctxOptions)
        );

        if (!gl) {
            canvas.insertAdjacentHTML("afterend", "<p class='shader-error'>WebGL is not supported in this browser.</p>");
            canvas.remove();
            return;
        }

        // Defer dimension setup to ensure CSS layout has resolved on mobile.
        // clientWidth/clientHeight can be 0 at DOMContentLoaded on some mobile browsers.
        const w = canvas.clientWidth || canvas.offsetWidth || 300;
        const h = canvas.clientHeight || canvas.offsetHeight || 400;
        canvas.width = w;
        canvas.height = h;

        gl.viewport(0, 0, canvas.width, canvas.height);

        const vertexSrc = `
  attribute vec2 position;
  void main() {
    gl_Position = vec4(position,0.0,1.0);
  }
  `;

        function compile(type, source) {
            const shaderObj = gl.createShader(type);
            gl.shaderSource(shaderObj, source);
            gl.compileShader(shaderObj);

            return shaderObj;
        }

        const vertexShader = compile(gl.VERTEX_SHADER, vertexSrc);
        const fragmentShader = compile(gl.FRAGMENT_SHADER, code);

        const program = gl.createProgram();

        gl.attachShader(program, vertexShader);
        gl.attachShader(program, fragmentShader);
        gl.linkProgram(program);
        gl.useProgram(program);

        gl.enable(gl.BLEND);
        gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);
        gl.clearColor(0, 0, 0, 0);

        const vertices = new Float32Array([-1, -1, 1, -1, -1, 1, 1, 1]);

        const buffer = gl.createBuffer();

        gl.bindBuffer(gl.ARRAY_BUFFER, buffer);
        gl.bufferData(gl.ARRAY_BUFFER, vertices, gl.STATIC_DRAW);

        const position = gl.getAttribLocation(program, "position");

        gl.enableVertexAttribArray(position);
        gl.vertexAttribPointer(position, 2, gl.FLOAT, false, 0, 0);

        let animFrameId = null;

        function render(time) {
            if (gl.isContextLost()) {
                animFrameId = null;
                return;
            }

            gl.clear(gl.COLOR_BUFFER_BIT);

            const u_resolution = gl.getUniformLocation(program, "u_resolution");
            const u_time = gl.getUniformLocation(program, "u_time");

            gl.uniform2f(u_resolution, canvas.width, canvas.height);
            gl.uniform1f(u_time, time * 0.001);

            gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);

            animFrameId = requestAnimationFrame(render);
        }

        canvas.addEventListener("webglcontextlost", (e) => {
            e.preventDefault();
            if (animFrameId !== null) {
                cancelAnimationFrame(animFrameId);
                animFrameId = null;
            }
        }, false);

        canvas.addEventListener("webglcontextrestored", () => {
            gl.enable(gl.BLEND);
            gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);
            gl.clearColor(0, 0, 0, 0);
            animFrameId = requestAnimationFrame(render);
        }, false);

        animFrameId = requestAnimationFrame(render);
    });
</script>
