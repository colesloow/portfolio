---
const { article } = Astro.props;
---

<article class="article-preview">
    <a href={`/blog/${article.slug}`} class="article-card">
        <h2>{article.data.title}</h2>

        <p class="article-date">
            {article.data.date.toDateString()}
        </p>

        <p class="article-summary">{article.data.summary}</p>
    </a>
</article>

<style>
    .article-preview {
        break-inside: avoid;
    }

    .article-card {
        display: block;

        background: var(--surface);
        padding: 20px;
        border-radius: 8px;

        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease;
    }

    .article-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
        background: var(--surface);
        -webkit-background-clip: unset;
        background-clip: unset;
        color: inherit;
        animation: none;
    }

    .article-card:hover h2 {
        background: linear-gradient(90deg, #ff6b8a, #ffb347, #6bcb77, #4d96ff, #c77dff, #ff6b8a, #ffb347, #6bcb77, #4d96ff, #c77dff, #ff6b8a);
        background-size: 200% 100%;
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        animation: shader-flow 4s linear infinite;
    }

    .article-card h2 {
        margin: 0 0 6px 0;
        font-size: 1.25rem;
    }

    .article-date {
        color: var(--text-muted);
        font-size: 0.9rem;
        margin-bottom: 6px;
    }

    .article-summary {
        color: var(--text-muted);
    }
</style>
