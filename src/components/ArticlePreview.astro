---
const { article } = Astro.props;
---

<article class="article-preview">
    <a href={`/blog/${article.slug}`} class="article-card">
        <h2>{article.data.title}</h2>

        <p class="article-date">
            {article.data.date.toDateString()}
        </p>

        <p class="article-summary">{article.data.summary}</p>
    </a>
</article>

<style>
    .article-preview {
        break-inside: avoid;
    }

    .article-card {
        display: block;

        background: var(--surface);
        padding: 20px;
        border-radius: 8px;

        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease;
    }

    .article-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
    }

    .article-card h2 {
        margin: 0 0 6px 0;
        font-size: 1.25rem;
    }

    .article-date {
        color: var(--text-muted);
        font-size: 0.9rem;
        margin-bottom: 6px;
    }

    .article-summary {
        color: var(--text-muted);
    }
</style>
