---
import Stepper from "./Stepper.astro";
import type { Step } from "./Stepper.astro";

function tag(label: string, color: string, bg: string) {
    return `<span style="display:inline-block;padding:1px 7px;border-radius:4px;font-size:0.78em;font-family:monospace;background:${bg};color:${color};border:1px solid ${color}55;">${label}</span>`;
}

const ORANGE = "#fb923c";
const GREEN = "#4ade80";
const RED = "#f87171";

const steps: Step[] = [
    {
        title: "The background grid",
        subtitle: "O(1) neighbor lookups",
        description: `<strong>The background grid</strong><br><br>
Before placing any points, an invisible grid covers the canvas. Each cell is <code>r / √2</code> wide, chosen so that at most one point can fit per cell.<br><br>
This bound makes neighbor checks constant time: to validate a candidate, only the 5×5 block of cells around it needs to be inspected, regardless of how many points already exist.`,
    },
    {
        title: "Seed point",
        subtitle: "Starting the active list",
        description: `<strong>Seed point</strong><br><br>
One point is placed at random and added to the ${tag("active", ORANGE, "#fb923c18")} list (the set of points that can still spawn neighbors).<br><br>
The active list is what drives the algorithm forward: as long as it is non-empty, the algorithm keeps trying to place new points.`,
    },
    {
        title: "The sampling ring",
        subtitle: "Where candidates are drawn from",
        description: `<strong>The sampling ring</strong><br><br>
A point is picked from the active list. A candidate is generated at a random position in the ring between <code>r</code> and <code>2r</code> around it.<br><br>
The inner boundary enforces the minimum distance. The outer boundary keeps the distribution dense: a candidate placed too far away would leave a gap.`,
    },
    {
        title: "Validating a candidate",
        subtitle: "Checking the grid cells",
        description: `<strong>Validating a candidate</strong><br><br>
The nearby grid cells are checked for conflicts. ${tag("✓ accepted", GREEN, "#4ade8018")} if no existing point is closer than <code>r</code>. ${tag("✗ rejected", RED, "#f8717118")} if any neighbor is within distance <code>r</code>.<br><br>
Up to <code>k = 30</code> candidates are tried per active point before giving up on it.`,
    },
    {
        title: "Exhaustion",
        subtitle: "Removing a saturated point",
        description: `<strong>Exhaustion and removal</strong><br><br>
If 30 attempts all fail, the active point is removed from the active list. The space around it is fully saturated: no valid position remains in its ring.<br><br>
The point stays on canvas but will generate no more children. The algorithm moves on to other active points.`,
    },
    {
        title: "Color propagation",
        subtitle: "Multiple fronts growing outward",
        description: `<strong>Color propagation</strong><br><br>
Each accepted point inherits its parent's color and joins the active list. With multiple seed colors, fronts grow simultaneously and meet naturally at their boundaries.<br><br>
The segment drawn between parent and child makes the lineage visible, forming a spanning tree rooted at each seed.`,
    },
    {
        title: "Full saturation",
        subtitle: "Active list empty: blue noise",
        description: `<strong>Full saturation</strong><br><br>
When the active list is empty, the algorithm stops. No valid position remains anywhere on the canvas, as every candidate would violate the minimum distance.<br><br>
The result is a <strong>maximal Poisson disc packing</strong>. This distribution is called <em>blue noise</em>: neither regular like a grid, nor clustered like white noise.`,
    },
];
---

<Stepper {steps}>
    <canvas slot="visual" data-poisson-canvas width="500" height="500"></canvas>
</Stepper>

<script>
    document.querySelectorAll<HTMLCanvasElement>("[data-poisson-canvas]").forEach(
        (canvas) => {
            const ctx = canvas.getContext("2d")!;
            const W = 500,
                H = 500;

            // Colors (dark theme, hardcoded for canvas)
            const BG = "#161a21";
            const TEXT = "#e6e8eb";
            const MUTED = "#9aa3ad";
            const ACCENT = "#22d3ee";
            const ORANGE = "#fb923c";
            const GREEN = "#4ade80";
            const RED = "#f87171";
            const PURPLE = "#a78bfa";
            const SEED_COLORS = [PURPLE, ACCENT];

            // Deterministic RNG (seed 42)
            let _seed = 42;
            function rng() {
                _seed |= 0;
                _seed = (_seed + 0x6d2b79f5) | 0;
                let t = Math.imul(_seed ^ (_seed >>> 15), 1 | _seed);
                t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
                return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
            }

            // Simulation
            const R = 28;
            const CW = R / Math.sqrt(2);
            const NC = Math.floor(W / CW);
            const NR = Math.floor(H / CW);

            const grid: (null | { x: number; y: number })[][] = Array.from(
                { length: NC },
                () => new Array(NR).fill(null)
            );

            interface Point {
                pos: { x: number; y: number };
                color: string;
                parent: { x: number; y: number } | null;
            }

            const seedPositions = [
                { x: 190, y: 260 },
                { x: 320, y: 220 },
            ];
            const seeds: Point[] = seedPositions.map((pos, n) => ({
                pos,
                color: SEED_COLORS[n],
                parent: null,
            }));

            seeds.forEach((s) => {
                grid[Math.floor(s.pos.x / CW)][Math.floor(s.pos.y / CW)] = s.pos;
            });

            const allPoints: Point[] = [...seeds];
            const active: Point[] = [...seeds];

            function dist(
                a: { x: number; y: number },
                b: { x: number; y: number }
            ) {
                return Math.hypot(a.x - b.x, a.y - b.y);
            }

            while (active.length > 0) {
                const idx = Math.floor(rng() * active.length);
                const parent = active[idx];
                let found = false;
                for (let attempt = 0; attempt < 30; attempt++) {
                    const angle = rng() * Math.PI * 2;
                    const mag = R + rng() * R;
                    const sx = parent.pos.x + Math.cos(angle) * mag;
                    const sy = parent.pos.y + Math.sin(angle) * mag;
                    const ci = Math.floor(sx / CW);
                    const cj = Math.floor(sy / CW);
                    if (ci < 0 || cj < 0 || ci >= NC || cj >= NR) continue;
                    if (grid[ci][cj]) continue;
                    let ok = true;
                    for (
                        let di = Math.max(ci - 2, 0);
                        di <= Math.min(ci + 2, NC - 1) && ok;
                        di++
                    ) {
                        for (
                            let dj = Math.max(cj - 2, 0);
                            dj <= Math.min(cj + 2, NR - 1) && ok;
                            dj++
                        ) {
                            const nb = grid[di][dj];
                            if (nb && dist({ x: sx, y: sy }, nb) < R) ok = false;
                        }
                    }
                    if (ok) {
                        const np: Point = {
                            pos: { x: sx, y: sy },
                            color: parent.color,
                            parent: parent.pos,
                        };
                        grid[ci][cj] = np.pos;
                        allPoints.push(np);
                        active.push(np);
                        found = true;
                        break;
                    }
                }
                if (!found) active.splice(idx, 1);
            }

            // Drawing helpers
            function clear() {
                ctx.fillStyle = BG;
                ctx.fillRect(0, 0, W, H);
            }

            function drawGrid(alpha = 0.2) {
                ctx.strokeStyle = `rgba(167, 139, 250, ${alpha})`;
                ctx.lineWidth = 0.5;
                for (let x = 0; x <= W; x += CW) {
                    ctx.beginPath();
                    ctx.moveTo(x, 0);
                    ctx.lineTo(x, H);
                    ctx.stroke();
                }
                for (let y = 0; y <= H; y += CW) {
                    ctx.beginPath();
                    ctx.moveTo(0, y);
                    ctx.lineTo(W, y);
                    ctx.stroke();
                }
            }

            function dot(
                x: number,
                y: number,
                color: string,
                r = 5,
                alpha = 1
            ) {
                ctx.globalAlpha = alpha;
                ctx.beginPath();
                ctx.arc(x, y, r, 0, Math.PI * 2);
                ctx.fillStyle = color;
                ctx.fill();
                ctx.globalAlpha = 1;
            }

            function annulus(
                x: number,
                y: number,
                rMin: number,
                rMax: number,
                color: string,
                alpha = 0.5
            ) {
                ctx.strokeStyle = color;
                ctx.lineWidth = 1.5;
                ctx.setLineDash([5, 4]);
                ctx.globalAlpha = alpha;
                ctx.beginPath();
                ctx.arc(x, y, rMin, 0, Math.PI * 2);
                ctx.stroke();
                ctx.beginPath();
                ctx.arc(x, y, rMax, 0, Math.PI * 2);
                ctx.stroke();
                ctx.globalAlpha = alpha * 0.12;
                ctx.fillStyle = color;
                ctx.beginPath();
                ctx.arc(x, y, rMax, 0, Math.PI * 2, false);
                ctx.arc(x, y, rMin, 0, Math.PI * 2, true);
                ctx.fill();
                ctx.setLineDash([]);
                ctx.globalAlpha = 1;
            }

            function activeRing(x: number, y: number) {
                ctx.strokeStyle = ORANGE;
                ctx.lineWidth = 1.5;
                ctx.setLineDash([3, 3]);
                ctx.globalAlpha = 0.7;
                ctx.beginPath();
                ctx.arc(x, y, 11, 0, Math.PI * 2);
                ctx.stroke();
                ctx.setLineDash([]);
                ctx.globalAlpha = 1;
            }

            function line(
                x1: number,
                y1: number,
                x2: number,
                y2: number,
                color: string,
                alpha = 0.4
            ) {
                ctx.globalAlpha = alpha;
                ctx.strokeStyle = color;
                ctx.lineWidth = 1;
                ctx.beginPath();
                ctx.moveTo(x1, y1);
                ctx.lineTo(x2, y2);
                ctx.stroke();
                ctx.globalAlpha = 1;
            }

            function cellHighlight(
                cx: number,
                cy: number,
                color: string,
                alpha = 0.18
            ) {
                const px = Math.floor(cx / CW) * CW;
                const py = Math.floor(cy / CW) * CW;
                ctx.globalAlpha = alpha;
                ctx.fillStyle = color;
                ctx.fillRect(px, py, CW, CW);
                ctx.globalAlpha = 1;
            }

            function lbl(
                text: string,
                x: number,
                y: number,
                color = TEXT,
                size = 11
            ) {
                ctx.font = `${size}px monospace`;
                ctx.fillStyle = color;
                ctx.fillText(text, x, y);
            }

            // Step renderers
            const drawFns = [
                // Step 0: Grid
                () => {
                    clear();
                    drawGrid(0.45);
                    ctx.strokeStyle = ACCENT;
                    ctx.lineWidth = 1.5;
                    ctx.strokeRect(80, 80, CW, CW);
                    lbl(`r / √2 ≈ ${CW.toFixed(1)}px`, 80 + CW + 8, 80 + CW / 2 + 4, ACCENT, 11);
                    lbl(`r = ${R}px`, 80, 72, ORANGE, 11);
                    lbl(`${NC} × ${NR} cells total`, W / 2 - 44, H - 12, MUTED, 10);
                },

                // Step 1: Seed
                () => {
                    clear();
                    drawGrid(0.1);
                    for (const s of seeds) {
                        cellHighlight(s.pos.x, s.pos.y, s.color);
                        dot(s.pos.x, s.pos.y, s.color, 7);
                        activeRing(s.pos.x, s.pos.y);
                    }
                    lbl("active list: 2 points", 10, H - 12, ORANGE, 10);
                },

                // Step 2: Sampling ring
                () => {
                    clear();
                    drawGrid(0.07);
                    for (const s of seeds) dot(s.pos.x, s.pos.y, s.color, 5, 0.5);
                    const f = seeds[1];
                    dot(f.pos.x, f.pos.y, f.color, 7);
                    activeRing(f.pos.x, f.pos.y);
                    annulus(f.pos.x, f.pos.y, R, R * 2, ORANGE);
                    const angle = 1.1,
                        mag = R * 1.45;
                    const cx = f.pos.x + Math.cos(angle) * mag;
                    const cy = f.pos.y + Math.sin(angle) * mag;
                    line(f.pos.x, f.pos.y, cx, cy, MUTED, 0.5);
                    dot(cx, cy, TEXT, 6);
                    lbl("candidate", cx + 8, cy + 4, MUTED, 10);
                    lbl("r", f.pos.x + R * 0.4, f.pos.y - 5, MUTED, 10);
                    lbl("2r", f.pos.x + R * 1.4, f.pos.y - 5, MUTED, 10);
                },

                // Step 3: Validation
                () => {
                    clear();
                    drawGrid(0.08);
                    for (const s of seeds) dot(s.pos.x, s.pos.y, s.color, 6, 0.6);
                    const f = seeds[1];
                    dot(f.pos.x, f.pos.y, f.color, 7);
                    activeRing(f.pos.x, f.pos.y);
                    // Accepted
                    const okX = f.pos.x + 38,
                        okY = f.pos.y - 48;
                    line(f.pos.x, f.pos.y, okX, okY, GREEN, 0.6);
                    cellHighlight(okX, okY, GREEN, 0.15);
                    dot(okX, okY, GREEN, 7);
                    ctx.globalAlpha = 0.35;
                    ctx.strokeStyle = GREEN;
                    ctx.lineWidth = 1;
                    ctx.setLineDash([2, 3]);
                    ctx.beginPath();
                    ctx.arc(okX, okY, R, 0, Math.PI * 2);
                    ctx.stroke();
                    ctx.setLineDash([]);
                    ctx.globalAlpha = 1;
                    lbl("✓ accepted", okX + 10, okY + 4, GREEN, 10);
                    // Rejected
                    const fp = seeds[0].pos;
                    const rx = (f.pos.x + fp.x) / 2 + 10,
                        ry = (f.pos.y + fp.y) / 2 - 10;
                    line(f.pos.x, f.pos.y, rx, ry, RED, 0.5);
                    dot(rx, ry, RED, 7);
                    ctx.globalAlpha = 0.35;
                    ctx.strokeStyle = RED;
                    ctx.lineWidth = 1;
                    ctx.setLineDash([2, 3]);
                    ctx.beginPath();
                    ctx.arc(rx, ry, R, 0, Math.PI * 2);
                    ctx.stroke();
                    ctx.beginPath();
                    ctx.moveTo(rx, ry);
                    ctx.lineTo(fp.x, fp.y);
                    ctx.stroke();
                    ctx.setLineDash([]);
                    ctx.globalAlpha = 1;
                    lbl("✗ rejected", rx + 10, ry + 4, RED, 10);
                    lbl("too close", rx + 10, ry + 16, MUTED, 9);
                },

                // Step 4: Exhaustion
                () => {
                    clear();
                    drawGrid(0.05);
                    const partial = allPoints.slice(0, 30);
                    for (const p of partial)
                        if (p.parent)
                            line(p.parent.x, p.parent.y, p.pos.x, p.pos.y, p.color, 0.25);
                    for (const p of partial) dot(p.pos.x, p.pos.y, p.color, 4);
                    const ex = partial[5];
                    ctx.strokeStyle = MUTED;
                    ctx.lineWidth = 1.5;
                    ctx.setLineDash([2, 3]);
                    ctx.globalAlpha = 0.7;
                    ctx.beginPath();
                    ctx.arc(ex.pos.x, ex.pos.y, 13, 0, Math.PI * 2);
                    ctx.stroke();
                    ctx.setLineDash([]);
                    ctx.globalAlpha = 1;
                    for (let i = 0; i < 8; i++) {
                        const a = (i / 8) * Math.PI * 2;
                        dot(
                            ex.pos.x + Math.cos(a) * R * 1.4,
                            ex.pos.y + Math.sin(a) * R * 1.4,
                            RED,
                            3,
                            0.35
                        );
                    }
                },

                // Step 5: Propagation
                () => {
                    clear();
                    drawGrid(0.04);
                    const partial = allPoints.slice(0, 90);
                    for (const p of partial)
                        if (p.parent)
                            line(p.parent.x, p.parent.y, p.pos.x, p.pos.y, p.color, 0.2);
                    for (const p of partial) dot(p.pos.x, p.pos.y, p.color, 4);
                    for (const p of partial.slice(-14)) {
                        ctx.strokeStyle = ORANGE;
                        ctx.lineWidth = 1.5;
                        ctx.setLineDash([2, 2]);
                        ctx.globalAlpha = 0.45;
                        ctx.beginPath();
                        ctx.arc(p.pos.x, p.pos.y, 10, 0, Math.PI * 2);
                        ctx.stroke();
                        ctx.setLineDash([]);
                        ctx.globalAlpha = 1;
                    }
                    lbl("active front", 10, H - 12, ORANGE, 10);
                },

                // Step 6: Full saturation
                () => {
                    clear();
                    drawGrid(0.025);
                    for (const p of allPoints)
                        if (p.parent)
                            line(p.parent.x, p.parent.y, p.pos.x, p.pos.y, p.color, 0.15);
                    for (const p of allPoints) dot(p.pos.x, p.pos.y, p.color, 4);
                    for (const p of allPoints) dot(p.pos.x, p.pos.y, "#fff", 1.5, 0.55);
                    lbl(
                        `${allPoints.length} points, active list empty`,
                        10,
                        H - 12,
                        GREEN,
                        10
                    );
                },
            ];

            // Initial draw
            drawFns[0]();

            // Listen for step changes from the parent Stepper
            canvas.closest(".stepper")!.addEventListener(
                "stepper:change",
                ((e: CustomEvent<{ step: number }>) => {
                    drawFns[e.detail.step]?.();
                }) as EventListener
            );
        }
    );
</script>
