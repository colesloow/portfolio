---
import { Image } from "astro:assets";

const { project } = Astro.props;
---

<article class="project-card">
    <a href={`/projects/${project.slug}`}>
        {
            project.data.thumbnail && (
                <div class="thumbnail">
                    <Image src={project.data.thumbnail} alt={project.data.title} width={800} height={600} />
                </div>
            )
        }

        <h2>{project.data.title}</h2>
        <p>{project.data.description}</p>
    </a>
</article>

<style>
    .project-card {
        break-inside: avoid;

        background: var(--surface);
        padding: 20px;
        margin-bottom: 24px;

        border-radius: 8px;

        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease;
    }

    .project-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
    }

    .project-card a {
        display: block;
        color: inherit;
    }

    .project-card a:hover {
        background: none;
        -webkit-background-clip: unset;
        background-clip: unset;
        color: inherit;
        animation: none;
    }

    .project-card a:hover h2 {
        background: linear-gradient(90deg, #ff6b8a, #ffb347, #6bcb77, #4d96ff, #c77dff, #ff6b8a, #ffb347, #6bcb77, #4d96ff, #c77dff, #ff6b8a);
        background-size: 200% 100%;
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        animation: shader-flow 4s linear infinite;
    }

    @media (prefers-reduced-motion: reduce) {
        .project-card a:hover h2 {
            animation: none;
            background: none;
            -webkit-background-clip: unset;
            background-clip: unset;
            color: inherit;
        }

        .project-card {
            transition: none;
        }

        .thumbnail img {
            transition: none;
        }
    }

    .project-card a:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: 4px;
    }

    .thumbnail {
        aspect-ratio: 16 / 9;
        overflow: hidden;
        border-radius: 6px;
    }

    .thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: cover;

        transition: transform 0.35s ease;
    }

    .project-card:hover img {
        transform: scale(1.05);
    }

    .project-card h2 {
        margin: 10px 0 6px 0;
        font-size: 1.25rem;
    }

    .project-card p {
        color: var(--text-muted);
    }
</style>
