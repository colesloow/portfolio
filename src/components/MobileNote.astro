---
const { message } = Astro.props;
---

<p class="mobile-note">{message}</p>

<style>
    .mobile-note {
        display: none;
    }

    @media (max-width: 768px) {
        .mobile-note {
            display: block;
            padding: 8px 14px;
            background: rgba(245, 200, 50, 0.07);
            border-left: 3px solid #f5c842;
            color: var(--text-muted);
            font-size: 0.85rem;
            border-radius: 0 6px 6px 0;
            margin: -24px 0 16px;
        }
    }
</style>
