---
const { code } = Astro.props;

const id = Math.random().toString(36).slice(2);
const canvasId = `shader-canvas-${id}`;
const editorId = `shader-editor-${id}`;
const errorId = `shader-error-${id}`;
const resetId = `shader-reset-${id}`;
const codeId = `shader-code-${id}`;
---

<div
    class="shader-playground"
    data-canvas-id={canvasId}
    data-editor-id={editorId}
    data-error-id={errorId}
    data-reset-id={resetId}
    data-code-id={codeId}
>
    <script type="text/plain" is:inline id={codeId} set:html={code}></script>

    <div class="editor-wrapper">
        <div id={editorId} class="editor"></div>

        <div class="shader-preview">
            <canvas id={canvasId} aria-label="Live shader preview"></canvas>
        </div>
    </div>

    <div class="shader-controls">
        <button id={resetId}>Reset shader</button>
    </div>

    <div id={errorId} class="shader-error" role="alert" aria-live="polite"></div>
</div>

<script>
    import { initShaderPlayground } from "../scripts/shader/initShaderPlayground";

    document.querySelectorAll<HTMLElement>(".shader-playground").forEach((el) => {
        const codeEl = document.getElementById(el.dataset.codeId!);
        initShaderPlayground({
            canvasId: el.dataset.canvasId!,
            editorId: el.dataset.editorId!,
            errorId: el.dataset.errorId!,
            resetId: el.dataset.resetId!,
            code: codeEl?.textContent ?? "",
        });
    });
</script>

<style>
    .shader-playground {
        margin: 40px 0;
    }

    /* grid */

    .editor-wrapper {
        display: grid;
        grid-template-columns: 1fr 260px;
        gap: 20px;
        align-items: start;
    }

    /* editor */

    .editor {
        border-radius: 8px;
        overflow: hidden;
        font-size: 14px;
    }

    /* preview */

    .shader-preview {
        width: 100%;
        aspect-ratio: 1;
        background: black;
        border-radius: 6px;
        overflow: hidden;
    }

    .shader-preview canvas {
        width: 100%;
        height: 100%;
    }

    /* controls */

    .shader-controls {
        margin-top: 12px;
    }

    .shader-controls button {
        background: var(--accent);
        border: none;
        padding: 6px 12px;
        border-radius: 6px;
        cursor: pointer;
        color: black;
        font-size: 13px;
    }

    :global(.light) .shader-controls button {
        color: white;
    }

    .shader-controls button:hover {
        filter: brightness(1.1);
    }

    /* error */

    .shader-error {
        margin-top: 10px;
        padding: 8px 12px;
        border-radius: 6px;

        background: rgba(255, 0, 120, 0.18);
        color: #ff5fa2;

        border: 1px solid rgba(255, 0, 120, 0.35);

        font-size: 14px;
        display: none;
    }

    :global(.light) .shader-error {
        background: rgba(255, 0, 100, 0.1);
        color: #b5004a;
        border-color: rgba(255, 0, 100, 0.4);
    }

    /* editor tweaks */

    .cm-editor {
        font-size: 13px;
    }

    /* mobile */

    @media (max-width: 800px) {
        .editor-wrapper {
            grid-template-columns: 1fr;
        }

        .shader-preview {
            max-width: 320px;
            margin-bottom: 12px;
        }
    }
</style>
