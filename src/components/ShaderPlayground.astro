---
// ShaderPlayground: live GLSL editor paired with a WebGL canvas preview.
// The initial shader code is embedded in a <script type="text/plain"> tag so it can be
// read by client-side JS without being executed. Random IDs allow multiple instances
// on the same page without ID collisions.
const { code, previewRatio = "1 / 1" } = Astro.props;

const id = Math.random().toString(36).slice(2);
const canvasId = `shader-canvas-${id}`;
const editorId = `shader-editor-${id}`;
const errorId = `shader-error-${id}`;
const resetId = `shader-reset-${id}`;
const codeId = `shader-code-${id}`;
---

<div
    class="shader-playground"
    data-canvas-id={canvasId}
    data-editor-id={editorId}
    data-error-id={errorId}
    data-reset-id={resetId}
    data-code-id={codeId}
>
    <script type="text/plain" is:inline id={codeId} set:html={code}></script>

    <div class="shader-header">
        <button id={resetId}>Reset shader</button>
        <span class="shader-lang">GLSL</span>
    </div>

    <div id={errorId} class="shader-error" role="alert" aria-live="polite"></div>

    <div class="editor-wrapper">
        <div class="editor-column">
            <div id={editorId} class="editor"></div>
        </div>

        <div class="resizer" aria-hidden="true"></div>

        <div class="shader-preview" style={`aspect-ratio: ${previewRatio};`}>
            <canvas id={canvasId} aria-label="Live shader preview"></canvas>
        </div>
    </div>
</div>

<script>
    import { initShaderPlayground } from "../scripts/shader/initShaderPlayground";

    // Editors taller than this pixel height get collapsed with a fade and a "Show more" button
    const THRESHOLD = 400;

    document.querySelectorAll<HTMLElement>(".shader-playground").forEach((el) => {
        const codeEl = document.getElementById(el.dataset.codeId!);
        initShaderPlayground({
            canvasId: el.dataset.canvasId!,
            editorId: el.dataset.editorId!,
            errorId: el.dataset.errorId!,
            resetId: el.dataset.resetId!,
            code: codeEl?.textContent ?? "",
        });

        requestAnimationFrame(() => {
            const editorEl = document.getElementById(el.dataset.editorId!);
            if (editorEl && editorEl.scrollHeight > THRESHOLD + 20) {
                editorEl.classList.add("collapsed-editor");
                const btn = document.createElement("button");
                btn.textContent = "Show more";
                btn.className = "code-expand-btn";
                btn.addEventListener("click", () => {
                    const collapsed = editorEl.classList.toggle("collapsed-editor");
                    btn.textContent = collapsed ? "Show more" : "Show less";
                });
                editorEl.insertAdjacentElement("afterend", btn);
            }
        });

        // Resizable split between editor and preview
        const wrapper = el.querySelector<HTMLElement>(".editor-wrapper");
        const resizer = el.querySelector<HTMLElement>(".resizer");
        const canvasEl = document.getElementById(el.dataset.canvasId!) as HTMLCanvasElement | null;

        if (wrapper && resizer && canvasEl) {
            // Keep canvas WebGL dimensions in sync with CSS layout size
            const ro = new ResizeObserver(() => {
                canvasEl.width = canvasEl.clientWidth;
                canvasEl.height = canvasEl.clientHeight;
            });
            ro.observe(canvasEl);

            let dragging = false;
            let startX = 0;
            let startPreviewWidth = 0;

            resizer.addEventListener("mousedown", (e) => {
                dragging = true;
                startX = e.clientX;
                const previewCol = wrapper.querySelector<HTMLElement>(".shader-preview");
                startPreviewWidth = previewCol ? previewCol.getBoundingClientRect().width : 260;
                document.body.style.cursor = "col-resize";
                document.body.style.userSelect = "none";
            });

            document.addEventListener("mousemove", (e) => {
                if (!dragging) return;
                const delta = startX - e.clientX; // drag left = preview grows
                const newWidth = Math.max(120, Math.min(600, startPreviewWidth + delta));
                wrapper.style.gridTemplateColumns = `1fr 10px ${newWidth}px`;
            });

            document.addEventListener("mouseup", () => {
                if (!dragging) return;
                dragging = false;
                document.body.style.cursor = "";
                document.body.style.userSelect = "";
            });
        }
    });
</script>

<style>
    .shader-playground {
        margin: 40px 0;
        max-width: 100%;
        overflow: hidden;
    }

    /* header */

    .shader-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 6px 12px;
        background: #111;
        border-radius: 8px 8px 0 0;
    }

    .shader-lang {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-muted);
        font-family: monospace;
    }

    .shader-header button {
        background: var(--accent);
        border: none;
        padding: 4px 10px;
        border-radius: 5px;
        cursor: pointer;
        color: black;
        font-size: 12px;
    }

    .shader-header button:hover {
        filter: brightness(1.1);
    }

    /* grid */

    .editor-wrapper {
        display: grid;
        grid-template-columns: 1fr 10px 260px;
        gap: 0;
        align-items: start;
    }

    .resizer {
        width: 10px;
        align-self: stretch;
        cursor: col-resize;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .resizer::after {
        content: "";
        display: block;
        width: 2px;
        height: 40px;
        border-radius: 1px;
        background: var(--text-muted, #555);
        opacity: 0.4;
        transition: opacity 0.15s;
    }

    .resizer:hover::after {
        opacity: 0.9;
    }

    /* editor */

    .editor-column {
        display: flex;
        flex-direction: column;
    }

    .editor {
        border-radius: 0 0 8px 8px;
        overflow: hidden;
        font-size: 14px;
    }

    .editor.collapsed-editor :global(.cm-editor) {
        max-height: 320px;
        overflow: hidden;
        mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
        -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    }

    .editor-column :global(.code-expand-btn) {
        margin-top: -6px;
        border-radius: 0 0 8px 8px;
    }

    /* preview */

    .shader-preview {
        width: 100%;
        aspect-ratio: 1;
        background: black;
        border-radius: 6px;
        overflow: hidden;
    }

    .shader-preview canvas {
        width: 100%;
        height: 100%;
    }

    /* error */

    .shader-error {
        padding: 10px 14px;
        border-left: 3px solid #ff2d78;
        background: rgba(255, 0, 100, 0.12);
        color: #ff5fa2;
        font-size: 13px;
        font-family: monospace;
        white-space: pre-wrap;
        display: none;
    }

    :global(.light) .shader-error {
        background: rgba(255, 0, 100, 0.07);
        color: #c0004e;
    }

    /* editor tweaks */

    .cm-editor {
        font-size: 13px;
    }

    /* mobile */

    @media (max-width: 800px) {
        .editor-wrapper {
            grid-template-columns: 1fr;
        }

        .resizer {
            display: none;
        }

        .shader-preview {
            max-width: 320px;
            margin: 0 auto 12px;
        }
    }
</style>
