---
const { code } = Astro.props;

const canvasId = `shader-${Math.random().toString(36).slice(2)}`;
const editorId = `editor-${Math.random().toString(36).slice(2)}`;
const errorId = `error-${Math.random().toString(36).slice(2)}`;
const resetId = `reset-${Math.random().toString(36).slice(2)}`;
---

<div class="shader-playground">
    <div class="editor-wrapper">
        <div id={editorId} class="editor"></div>

        <div class="shader-preview">
            <canvas id={canvasId}></canvas>
        </div>
    </div>

    <div class="shader-controls">
        <button id={resetId}>Reset shader</button>
    </div>

    <div id={errorId} class="shader-error"></div>
</div>

<script type="module" define:vars={{ canvasId, editorId, errorId, resetId, code }}>
    import { initShaderPlayground } from "/src/scripts/shader/initShaderPlayground.ts";

    initShaderPlayground({
        canvasId,
        editorId,
        errorId,
        resetId,
        code,
    });
</script>

<style>
    .shader-playground {
        margin: 40px 0;
    }

    /* grid */

    .editor-wrapper {
        display: grid;
        grid-template-columns: 1fr 260px;
        gap: 20px;
        align-items: start;
    }

    /* editor */

    .editor {
        border-radius: 8px;
        overflow: hidden;
        font-size: 14px;
    }

    /* preview */

    .shader-preview {
        width: 100%;
        aspect-ratio: 1;
        background: black;
        border-radius: 6px;
        overflow: hidden;
    }

    .shader-preview canvas {
        width: 100%;
        height: 100%;
    }

    /* controls */

    .shader-controls {
        margin-top: 12px;
    }

    .shader-controls button {
        background: var(--accent);
        border: none;
        padding: 6px 12px;
        border-radius: 6px;
        cursor: pointer;
        color: black;
        font-size: 13px;
    }

    .shader-controls button:hover {
        filter: brightness(1.1);
    }

    /* error */

    .shader-error {
        margin-top: 10px;
        padding: 8px 12px;
        border-radius: 6px;

        background: rgba(255, 0, 120, 0.18);
        color: #ff5fa2;

        border: 1px solid rgba(255, 0, 120, 0.35);

        font-size: 14px;
        display: none;
    }

    /* editor tweaks */

    .cm-editor {
        font-size: 13px;
    }

    /* mobile */

    @media (max-width: 800px) {
        .editor-wrapper {
            grid-template-columns: 1fr;
        }

        .shader-preview {
            max-width: 320px;
            margin-bottom: 12px;
        }
    }
</style>
