---
const { code } = Astro.props;

const canvasId = `shader-${Math.random().toString(36).slice(2)}`;
const editorId = `editor-${Math.random().toString(36).slice(2)}`;
const errorId = `error-${Math.random().toString(36).slice(2)}`;
const resetId = `reset-${Math.random().toString(36).slice(2)}`;
---

<div class="shader-playground">
    <div class="editor-wrapper">
        <div id={editorId} class="editor"></div>

        <div class="shader-preview">
            <canvas id={canvasId}></canvas>
        </div>
    </div>

    <div class="shader-controls">
        <button id={resetId}>Reset shader</button>
    </div>

    <div id={errorId} class="shader-error"></div>
</div>

<style>
    .shader-playground {
        margin: 40px 0;
    }

    /* main grid */

    .editor-wrapper {
        display: grid;
        grid-template-columns: 1fr 260px;
        gap: 20px;
        align-items: start;
    }

    /* code editor */

    .editor {
        border-radius: 8px;
        overflow: hidden;
        font-size: 14px;
    }

    /* preview column */

    .shader-preview {
        width: 100%;
        aspect-ratio: 1;
        background: black;
        border-radius: 6px;
        overflow: hidden;
    }

    .shader-preview canvas {
        width: 100%;
        height: 100%;
    }

    /* controls */

    .shader-controls {
        margin-top: 12px;
    }

    .shader-controls button {
        background: var(--accent);
        border: none;
        padding: 6px 12px;
        border-radius: 6px;
        cursor: pointer;
    }

    /* error */

    .shader-error {
        margin-top: 10px;
        padding: 8px 12px;
        border-radius: 6px;
        background: #3a0000;
        color: #ff8080;
        font-size: 14px;
        display: none;
    }

    .cm-editor {
        font-size: 13px;
    }

    /* mobile */

    @media (max-width: 800px) {
        .editor-wrapper {
            grid-template-columns: 1fr;
        }

        .shader-preview {
            max-width: 320px;
            margin-bottom: 12px;
        }
    }
</style>

<script type="module" define:vars={{ canvasId, editorId, errorId, resetId, code }}>
    import { EditorView, basicSetup } from "https://esm.sh/codemirror";
    import { EditorState } from "https://esm.sh/@codemirror/state";
    import { cpp } from "https://esm.sh/@codemirror/lang-cpp";
    import { oneDark } from "https://esm.sh/@codemirror/theme-one-dark";

    const canvas = document.getElementById(canvasId);
    const gl = canvas.getContext("webgl");

    const errorBox = document.getElementById(errorId);
    const resetBtn = document.getElementById(resetId);

    const initialCode = code;

    canvas.width = canvas.clientWidth;
    canvas.height = canvas.clientHeight;

    /* CodeMirror */

    const editor = new EditorView({
        state: EditorState.create({
            doc: code,
            extensions: [
                basicSetup,
                cpp(),
                oneDark,
                EditorView.lineWrapping,
                EditorView.updateListener.of((update) => {
                    if (update.docChanged) {
                        compile();
                    }
                }),
            ],
        }),
        parent: document.getElementById(editorId),
    });

    /* shader */

    const vertexSrc = `
attribute vec2 position;
void main(){
gl_Position = vec4(position,0.0,1.0);
}
`;

    function showError(msg) {
        errorBox.style.display = "block";
        errorBox.textContent = msg;
    }

    function clearError() {
        errorBox.style.display = "none";
        errorBox.textContent = "";
    }

    function compileShader(type, source) {
        const shader = gl.createShader(type);

        gl.shaderSource(shader, source);
        gl.compileShader(shader);

        if (!gl.getShaderParameter(shader, gl.COMPILE_STATUS)) {
            showError(gl.getShaderInfoLog(shader));
            return null;
        }

        return shader;
    }

    function createProgram(fragment) {
        clearError();

        const vs = compileShader(gl.VERTEX_SHADER, vertexSrc);
        const fs = compileShader(gl.FRAGMENT_SHADER, fragment);

        if (!vs || !fs) return null;

        const program = gl.createProgram();

        gl.attachShader(program, vs);
        gl.attachShader(program, fs);

        gl.linkProgram(program);

        if (!gl.getProgramParameter(program, gl.LINK_STATUS)) {
            showError(gl.getProgramInfoLog(program));
            return null;
        }

        return program;
    }

    let program = createProgram(code);

    /* quad */

    const vertices = new Float32Array([-1, -1, 1, -1, -1, 1, 1, 1]);

    const buffer = gl.createBuffer();

    gl.bindBuffer(gl.ARRAY_BUFFER, buffer);
    gl.bufferData(gl.ARRAY_BUFFER, vertices, gl.STATIC_DRAW);

    /* compile */

    function compile() {
        const src = editor.state.doc.toString();

        const newProgram = createProgram(src);

        if (newProgram) {
            program = newProgram;
        }
    }

    /* reset */

    resetBtn.addEventListener("click", () => {
        editor.dispatch({
            changes: {
                from: 0,
                to: editor.state.doc.length,
                insert: initialCode,
            },
        });

        compile();
    });

    /* render */

    function render(time) {
        if (!program) {
            requestAnimationFrame(render);
            return;
        }

        gl.viewport(0, 0, canvas.width, canvas.height);

        gl.useProgram(program);

        const position = gl.getAttribLocation(program, "position");

        gl.enableVertexAttribArray(position);
        gl.vertexAttribPointer(position, 2, gl.FLOAT, false, 0, 0);

        const res = gl.getUniformLocation(program, "u_resolution");
        const t = gl.getUniformLocation(program, "u_time");

        if (res) gl.uniform2f(res, canvas.width, canvas.height);
        if (t) gl.uniform1f(t, time * 0.001);

        gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);

        requestAnimationFrame(render);
    }

    requestAnimationFrame(render);
</script>
