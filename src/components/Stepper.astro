---
// Stepper: generic step-by-step walkthrough component.
// The step panel on the left lists all steps for direct navigation.
// The main area holds a named slot "visual" (typically a canvas) and a description panel.
// Navigation dispatches a "stepper:change" CustomEvent on the .stepper element so that
// child components can react by updating the visual independently.
// On mobile the step panel is hidden; a "X / N" counter replaces it.

export interface Step {
    title: string;
    subtitle?: string;
    description: string; // HTML allowed
}

const { steps } = Astro.props as { steps: Step[] };
---

<div
    class="stepper"
    data-descriptions={JSON.stringify(steps.map((s) => s.description))}
    role="region"
    aria-label="Step-by-step walkthrough"
>
    <div class="stepper-panel" role="tablist" aria-label="Steps">
        {
            steps.map((step, i) => (
                <button
                    class:list={["step-btn", { active: i === 0 }]}
                    data-idx={i}
                    role="tab"
                    aria-selected={i === 0 ? "true" : "false"}
                    aria-controls="stepper-desc"
                >
                    <div class="step-num">STEP {i + 1}</div>
                    <div class="step-title">{step.title}</div>
                    {step.subtitle && <div class="step-sub">{step.subtitle}</div>}
                </button>
            ))
        }
    </div>

    <div class="stepper-main">
        <div class="stepper-visual">
            <slot name="visual" />
        </div>
        <div class="stepper-nav">
            <button class="nav-btn prev-btn" disabled aria-label="Previous step">← Previous</button>
            <span class="step-counter" aria-hidden="true">1 / {steps.length}</span>
            <button class="nav-btn next-btn" aria-label="Next step">Next →</button>
        </div>
        <div
            id="stepper-desc"
            class="stepper-desc"
            role="tabpanel"
            aria-live="polite"
            aria-atomic="true"
            set:html={steps[0].description}
        />
    </div>
</div>

<script>
    document.querySelectorAll<HTMLElement>(".stepper").forEach((el) => {
        // Descriptions are serialized into a data attribute at build time to avoid
        // inline script islands and keep the component self-contained
        const descriptions: string[] = JSON.parse(el.dataset.descriptions!);
        const stepBtns = el.querySelectorAll<HTMLElement>(".step-btn");
        const desc = el.querySelector<HTMLElement>(".stepper-desc")!;
        const prevBtn = el.querySelector<HTMLButtonElement>(".prev-btn")!;
        const nextBtn = el.querySelector<HTMLButtonElement>(".next-btn")!;
        let current = 0;

        const counter = el.querySelector<HTMLElement>(".step-counter")!;

        function go(idx: number) {
            current = idx;
            stepBtns.forEach((btn, i) => {
                btn.classList.toggle("active", i === idx);
                btn.setAttribute("aria-selected", String(i === idx));
            });
            desc.innerHTML = descriptions[idx];
            counter.textContent = `${idx + 1} / ${descriptions.length}`;
            prevBtn.disabled = idx === 0;
            nextBtn.disabled = idx === descriptions.length - 1;
            el.dispatchEvent(new CustomEvent("stepper:change", { detail: { step: idx } }));
        }

        stepBtns.forEach((btn, i) => btn.addEventListener("click", () => go(i)));
        prevBtn.addEventListener("click", () => go(current - 1));
        nextBtn.addEventListener("click", () => go(current + 1));
    });
</script>

<style>
    .stepper {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 20px;
        margin: 2rem 0;
        align-items: start;
    }

    /* --- Step panel --- */

    .stepper-panel {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .step-btn {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 11px 13px;
        cursor: pointer;
        text-align: left;
        color: var(--text);
        font-family: monospace;
        width: 100%;
        transition:
            border-color 0.15s,
            background 0.15s;
    }

    .step-btn:hover {
        border-color: var(--text-muted);
    }

    .step-btn.active {
        border-color: var(--accent);
        background: rgba(34, 211, 238, 0.05);
    }

    .step-num {
        font-size: 0.6rem;
        color: var(--accent);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 3px;
    }

    .step-title {
        font-size: 0.8rem;
        font-weight: 600;
        line-height: 1.3;
        font-family: system-ui, sans-serif;
    }

    .step-sub {
        font-size: 0.67rem;
        color: var(--text-muted);
        margin-top: 3px;
        line-height: 1.4;
    }

    /* --- Main area --- */

    .stepper-main {
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-width: 0;
    }

    .stepper-visual {
        width: 100%;
        aspect-ratio: 1;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
    }

    .stepper-visual :global(canvas) {
        width: 100%;
        height: 100%;
        display: block;
    }

    /* --- Description --- */

    .stepper-desc {
        font-size: 0.84rem;
        line-height: 1.65;
        color: var(--text-muted);
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 13px 16px;
    }

    .stepper-desc :global(strong) {
        color: var(--text);
    }

    .stepper-desc :global(code) {
        background: rgba(255, 255, 255, 0.07);
        padding: 1px 5px;
        border-radius: 3px;
        font-size: 0.82rem;
        font-family: monospace;
    }

    .stepper-desc :global(em) {
        color: var(--text);
    }

    :global(.light) .stepper-desc :global(code) {
        background: rgba(0, 0, 0, 0.06);
    }

    /* --- Nav --- */

    .stepper-nav {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
        align-items: center;
    }

    .step-counter {
        display: none;
        font-family: monospace;
        font-size: 0.75rem;
        color: var(--text-muted);
        flex: 1;
        text-align: center;
    }

    .nav-btn {
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 7px 16px;
        font-family: monospace;
        font-size: 0.75rem;
        color: var(--text);
        cursor: pointer;
        transition:
            border-color 0.15s,
            color 0.15s;
    }

    .nav-btn:hover:not(:disabled) {
        border-color: var(--accent);
        color: var(--accent);
    }

    .nav-btn:disabled {
        opacity: 0.3;
        cursor: default;
    }

    /* --- Mobile --- */

    @media (max-width: 700px) {
        .stepper {
            grid-template-columns: 1fr;
        }

        .stepper-panel {
            display: none;
        }

        .step-counter {
            display: block;
        }

        .stepper-nav {
            justify-content: space-between;
        }
    }
</style>
