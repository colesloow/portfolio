---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const projects = await getCollection("projects", ({ data }) => !data.draft);

    return projects.map((project) => ({
        params: { slug: project.slug },
        props: { project },
    }));
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<BaseLayout title={project.data.title} description={project.data.description} ogImage={project.data.thumbnail?.src}>
    <main class="container">
        {
            project.data.gallery && project.data.gallery.length > 0 && (
                <section class="project-cover">
                    <Image
                        src={project.data.gallery[0]}
                        alt={`${project.data.title} - cover image`}
                        class="gallery-img"
                    />
                </section>
            )
        }

        <section class="project-header">
            <h1>{project.data.title}</h1>

            <p class="project-description">
                {project.data.description}
            </p>
        </section>

        <article class="project-content">
            <Content />
        </article>

        {
            project.data.gallery && project.data.gallery.length > 1 && (
                <section class="project-gallery" aria-label="Project images">
                    {project.data.gallery.slice(1).map((img, i) => (
                        <Image
                            src={img}
                            alt={`${project.data.title} - image ${i + 2}`}
                            class="gallery-img"
                        />
                    ))}
                </section>
            )
        }

        <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer" hidden>
            <button class="lightbox-prev" id="lightbox-prev" aria-label="Previous image">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
            </button>

            <img id="lightbox-img" alt="" />

            <button class="lightbox-next" id="lightbox-next" aria-label="Next image">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
            </button>
        </div>

        {
            project.data.tags && (
                <ul class="project-tags" aria-label="Tags">
                    {project.data.tags.map((tag) => (
                        <li>{tag}</li>
                    ))}
                </ul>
            )
        }

        {
            project.data.links && (
                <div class="project-links">
                    {project.data.links.github && (
                        <a
                            href={project.data.links.github}
                            class="github-cta"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="View source code on GitHub, opens in new tab"
                        >
                            <svg class="github-logo" viewBox="0 0 98 96" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path fill-rule="evenodd" clip-rule="evenodd" d="M48.854 0C21.839 0 0 22 0 49.217c0 21.756 13.993 40.172 33.405 46.69 2.427.49 3.316-1.059 3.316-2.362 0-1.141-.08-5.052-.08-9.127-13.59 2.934-16.42-5.867-16.42-5.867-2.184-5.704-5.42-7.17-5.42-7.17-4.448-3.015.324-3.015.324-3.015 4.934.326 7.523 5.052 7.523 5.052 4.367 7.496 11.404 5.378 14.235 4.074.404-3.178 1.699-5.378 3.074-6.6-10.839-1.141-22.243-5.378-22.243-24.283 0-5.378 1.94-9.778 5.014-13.2-.485-1.222-2.184-6.275.486-13.038 0 0 4.125-1.304 13.426 5.052a46.97 46.97 0 0 1 12.214-1.63c4.125 0 8.33.571 12.213 1.63 9.302-6.356 13.427-5.052 13.427-5.052 2.67 6.763.97 11.816.485 13.038 3.155 3.422 5.015 7.822 5.015 13.2 0 18.905-11.404 23.06-22.324 24.283 1.78 1.548 3.316 4.481 3.316 9.126 0 6.6-.08 11.897-.08 13.526 0 1.304.89 2.853 3.316 2.364 19.412-6.52 33.405-24.935 33.405-46.691C97.707 22 75.788 0 48.854 0z" fill="currentColor"/>
                            </svg>
                            <div class="github-cta-text">
                                <span class="github-cta-label">View on GitHub</span>
                                <span class="github-cta-sub">Source code and more details</span>
                            </div>
                            <svg class="github-cta-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <line x1="7" y1="17" x2="17" y2="7"></line>
                                <polyline points="7 7 17 7 17 17"></polyline>
                            </svg>
                        </a>
                    )}
                    {project.data.links.demo && (
                        <a
                            href={project.data.links.demo}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="View live demo, opens in new tab"
                        >
                            Demo
                        </a>
                    )}
                </div>
            )
        }

    </main>
</BaseLayout>

<style>
    .project-cover {
        margin-top: 40px;
        margin-bottom: 40px;

        aspect-ratio: 16 / 9;
        overflow: hidden;

        border-radius: 10px;

        cursor: zoom-in;
    }

    .project-cover img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .project-header h1 {
        margin-bottom: 10px;
    }

    .project-description {
        color: var(--text-muted);
    }

    /* Override the article-level constraints for project body text */
    .project-content {
        max-width: none;
        margin: 16px 0 0 0;
        padding: 0;
    }

    .project-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin: 20px 0;
        list-style: none;
        padding: 0;
    }

    .project-tags li {
        background: var(--surface);
        padding: 6px 10px;
        border-radius: 6px;
    }

    .project-links {
        display: flex;
        gap: 20px;
        margin: 20px 0 40px 0;
    }

    .github-cta {
        display: inline-flex;
        align-items: center;
        gap: 14px;
        padding: 14px 18px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        text-decoration: none;
        color: var(--text);
        transition: border-color 0.15s, background 0.15s;
    }

    .github-cta:hover {
        border-color: var(--accent);
        background: rgba(34, 211, 238, 0.04);
        color: var(--text);
    }

    .github-cta:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
    }

    .github-logo {
        width: 28px;
        height: 28px;
        flex-shrink: 0;
        color: var(--text);
    }

    .github-cta-text {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .github-cta-label {
        font-size: 0.9rem;
        font-weight: 600;
    }

    .github-cta-sub {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .github-cta-arrow {
        margin-left: auto;
        color: var(--text-muted);
        flex-shrink: 0;
        transition: color 0.15s;
    }

    .github-cta:hover .github-cta-arrow {
        color: var(--accent);
    }
    .project-gallery {
        margin: 40px 0;

        columns: 3;
        column-gap: 16px;
    }

    .project-gallery img {
        width: 100%;
        height: auto;
        margin-bottom: 16px;

        border-radius: 8px;

        cursor: zoom-in;
        display: block;
    }

    /* Keyboard focus indicator on interactive gallery images */
    .gallery-img:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: 8px;
    }

    .lightbox {
        position: fixed;
        inset: 0;

        background: rgba(0, 0, 0, 0.9);

        display: none;
        align-items: center;
        justify-content: center;

        z-index: 2000;
    }

    /* hidden attribute overrides display:none but we also use JS; keep in sync */
    .lightbox:not([hidden]) {
        display: flex;
    }

    .lightbox img {
        max-width: 90vw;
        max-height: 90vh;
    }

    .lightbox button {
        position: absolute;

        top: 50%;
        transform: translateY(-50%);

        background: rgba(0, 0, 0, 0.4);
        border: none;

        color: white;

        padding: 10px 16px;

        display: flex;
        align-items: center;
        justify-content: center;


        cursor: pointer;

        border-radius: 6px;
    }

    .lightbox-prev {
        left: 40px;
    }

    .lightbox-next {
        right: 40px;
    }

    .lightbox button:hover {
        background: rgba(0, 0, 0, 0.7);
    }

    .lightbox button:focus-visible {
        outline: 2px solid white;
        outline-offset: 2px;
    }

    @media (max-width: 900px) {
        .project-gallery {
            columns: 2;
        }
    }

    @media (max-width: 600px) {
        .project-gallery {
            columns: 1;
        }
    }
</style>

<script>
    const images = Array.from(document.querySelectorAll<HTMLImageElement>(".gallery-img"));

    const lightbox = document.getElementById("lightbox");
    const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement | null;

    const prevBtn = document.getElementById("lightbox-prev") as HTMLButtonElement | null;
    const nextBtn = document.getElementById("lightbox-next") as HTMLButtonElement | null;

    let currentIndex = 0;
    let lastFocused: HTMLElement | null = null;

    function showImage(index: number) {
        if (!lightboxImg) return;

        currentIndex = index;

        const img = images[index];
        lightboxImg.src = img.src;
        lightboxImg.alt = img.alt;
    }

    function openLightbox(index: number, trigger: HTMLElement) {
        if (!lightbox || !prevBtn) return;
        lastFocused = trigger;
        lightbox.removeAttribute("hidden");
        lightbox.style.display = "flex";
        showImage(index);
        prevBtn.focus();
    }

    function closeLightbox() {
        if (!lightbox) return;
        lightbox.setAttribute("hidden", "");
        lightbox.style.display = "none";
        if (lastFocused) lastFocused.focus();
    }

    if (lightbox && lightboxImg && prevBtn && nextBtn) {
        // Make each gallery image reachable and activatable via keyboard
        images.forEach((img, index) => {
            img.setAttribute("tabindex", "0");
            img.setAttribute("role", "button");

            img.addEventListener("click", () => openLightbox(index, img));

            img.addEventListener("keydown", (e) => {
                if (e.key === "Enter" || e.key === " ") {
                    e.preventDefault();
                    openLightbox(index, img);
                }
            });
        });

        prevBtn.addEventListener("click", (e) => {
            e.stopPropagation();
            showImage((currentIndex - 1 + images.length) % images.length);
        });

        nextBtn.addEventListener("click", (e) => {
            e.stopPropagation();
            showImage((currentIndex + 1) % images.length);
        });

        lightbox.addEventListener("click", (e) => {
            if (e.target === lightbox) closeLightbox();
        });

        document.addEventListener("keydown", (e) => {
            if (lightbox.style.display !== "flex") return;

            if (e.key === "ArrowRight") showImage((currentIndex + 1) % images.length);
            if (e.key === "ArrowLeft") showImage((currentIndex - 1 + images.length) % images.length);
            if (e.key === "Escape") closeLightbox();
        });
    }
</script>
