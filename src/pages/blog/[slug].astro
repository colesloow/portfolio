---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const articles = await getCollection("blog", ({ data }) => !data.draft);

    return articles.map((article) => ({
        params: { slug: article.slug },
        props: { article },
    }));
}

const { article } = Astro.props;
const { Content } = await article.render();

const { date, updatedDate } = article.data;
const toYMD = (d: Date) => d.toISOString().slice(0, 10);
const showUpdated = updatedDate && toYMD(updatedDate) !== toYMD(date);
---

<BaseLayout title={article.data.title} description={article.data.summary}>
    <article class="article-content">
        <header class="article-header">
            <h1>{article.data.title}</h1>

            <p class="article-meta">
                {date.toDateString()}
                {showUpdated && <span class="article-updated"> · Updated {updatedDate!.toDateString()}</span>}
            </p>
        </header>

        <Content />
    </article>
</BaseLayout>

<script>
    // Language labels on code blocks
    document.querySelectorAll<HTMLElement>(".article-content pre > code[class]").forEach((code) => {
        const match = code.className.match(/language-(\w+)/);
        if (match) {
            const lang = match[1] === "csharp" ? "C#" : match[1];
            const pre = code.closest("pre") as HTMLElement;
            if (pre) pre.dataset.language = lang;
        }
    });

    // Image grid captions: tap to toggle on mobile
    document.querySelectorAll<HTMLElement>(".image-grid figure").forEach((fig) => {
        fig.addEventListener("click", () => fig.classList.toggle("caption-visible"));
    });

    // Collapsible code blocks
    const THRESHOLD = 320;
    document.querySelectorAll<HTMLElement>(".article-content pre").forEach((pre) => {
        if (pre.scrollHeight > THRESHOLD + 20) {
            pre.classList.add("collapsed");
            const lang = pre.dataset.language ?? "code";
            const btn = document.createElement("button");
            btn.textContent = "Show more";
            btn.className = "code-expand-btn";
            btn.setAttribute("aria-expanded", "false");
            btn.setAttribute("aria-label", `Show more of this ${lang} block`);
            btn.addEventListener("click", () => {
                const collapsed = pre.classList.toggle("collapsed");
                btn.textContent = collapsed ? "Show more" : "Show less";
                btn.setAttribute("aria-expanded", String(!collapsed));
                btn.setAttribute("aria-label", collapsed ? `Show more of this ${lang} block` : `Show less of this ${lang} block`);
            });
            pre.insertAdjacentElement("afterend", btn);
        }
    });
</script>
