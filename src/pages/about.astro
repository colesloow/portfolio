        </div>
    </main>
</BaseLayout>

<style>
    .about {
        max-width: 680px;
        margin: 0 auto;
        padding-bottom: 80px;
    }

    .about-body {
        font-size: 1.05rem;
        line-height: 1.75;
    }

    .about-body p {
        margin: 1.2rem 0;
        color: var(--text);
    }

    .social-links {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 20px;
        margin-top: 2.5rem;
    }

    .social-links a {
        color: var(--text);
        transition: color 0.15s ease;
    }

    .social-links a:hover {
        color: var(--accent);
    }
</style>
