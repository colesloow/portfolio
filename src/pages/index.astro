---
import HomeLayout from "../layouts/HomeLayout.astro";
---

<HomeLayout>
    <section class="canvas-container" aria-hidden="true">
        <canvas id="home-canvas"></canvas>
    </section>
</HomeLayout>

<style>
    .canvas-container {
        width: 100%;
        height: calc(100vh - 120px);
        overflow: hidden;
    }

    canvas {
        display: block;
        width: 100%;
        height: 100%;
        cursor: crosshair;
    }
</style>

<script>
    import "../scripts/homeCanvas";
</script>
