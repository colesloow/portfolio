---
import HomeLayout from "../layouts/HomeLayout.astro";
---

<HomeLayout>
    <section class="canvas-container">
        <canvas id="home-canvas"></canvas>
    </section>
</HomeLayout>

<style>
    .canvas-container {
        width: 100%;
        height: calc(100vh - 120px);
        display: flex;
    }

    canvas {
        width: 100%;
        height: 100%;
    }
</style>
